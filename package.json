{
  "name": "hospital-ops-report",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node server/server.js",
    "serve": "node tools/serve.mjs",
    "prepare:www": "node tools/prepare-www.mjs",
    "cap:init": "npm install @capacitor/core @capacitor/cli @capacitor/android",
